{
  "name": "@kode/vscode-extension",
  "displayName": "Kode",
  "description": "AI-powered code generation, inline review, and Git automation",
  "version": "0.0.1",
  "publisher": "kode",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other", "Machine Learning", "Linters"],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "lint": "eslint src --ext .ts",
    "clean": "rm -rf dist",
    "vscode:prepublish": "npm run build"
  },
  "contributes": {
    "commands": [
      {
        "command": "kode.helloWorld",
        "title": "Kode: Hello World"
      }
    ]
  },
  "dependencies": {
    "@kode/core": "*"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^2.3.9",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}